  "keyFeatures": [
    "JWT-based stateless authentication with BCrypt password hashing",
    "Table (mesa) lifecycle management: LIBRE → OCUPADA → LIBRE with automatic time tracking",
    "Product catalog management with availability control",
    "Per-table consumption (consumo) recording during active sessions",
    "Automatic session (sesion) creation and billing on table close",
    "Revenue reports: daily, weekly, monthly with breakdown by table and product",
    "Top products ranking and average ticket analytics",
    "Soft-delete for tables with historical sessions",
    "PostgreSQL persistence with Spring Data JPA and automatic schema management",
    "Docker Compose setup for local development database"
  ],
  "publicApiSurface": [
